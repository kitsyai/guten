{
  "name": "@kitsyai/guten",
  "version": "0.1.0",
  "description": "Multi-format, multi-runtime templating engine (Liquid) — Node + browser. The JS runtime of kitsyai/guten.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "liquidjs": "^10.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kitsyai/guten",
    "directory": "js"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
