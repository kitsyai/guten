{
  "name": "@kitsy/guten",
  "version": "0.2.5",
  "description": "Multi-format, multi-runtime templating engine (Liquid) â€” Node + browser. The JS runtime of kitsyai/guten.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.umd.js",
  "jsdelivr": "./dist/index.umd.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.umd.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:node": "vitest run -t \"gutenkit workflow \\(node\"",
    "test:browser": "vitest run -t \"browser-like via UMD\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "liquidjs": "^10.16.0"
  },
  "devDependencies": {
    "@kitsy/gutenkit": "0.2.4",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kitsyai/guten",
    "directory": "js"
  }
}
