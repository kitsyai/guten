{
  "name": "@kitsy/guten",
  "version": "0.4.0",
  "description": "Multi-format, multi-runtime templating engine (Liquid) for Node and browser. The JS runtime of kitsyai/guten.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.umd.js",
  "jsdelivr": "./dist/index.umd.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.umd.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs",
      "default": "./dist/react.umd.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run --exclude browser-tests",
    "test:node": "vitest run -t \"gutenkit workflow \\(node\"",
    "test:browser:vm": "npm run build && vitest run test -t \"browser-like via UMD\" --exclude browser-tests",
    "test:browser:e2e": "npm run build && npx playwright test",
    "test:browser": "npm run test:browser:vm && npm run test:browser:e2e",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "liquidjs": "^10.16.0"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@kitsy/gutenkit": "0.2.6",
    "@types/node": "^22.10.0",
    "@playwright/test": "^1.54.1",
    "tsup": "^8.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kitsyai/guten",
    "directory": "js"
  }
}

